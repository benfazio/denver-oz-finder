generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Property {
  id              String   @id @default(cuid())

  // Location
  address         String
  city            String   @default("Denver")
  state           String   @default("CO")
  zipCode         String?
  latitude        Float
  longitude       Float

  // OZ classification
  inOpportunityZone Boolean  @default(false)
  censusTract       String?
  ozName            String?
  ozDesignation     String?
  county            String?

  // Assessor IDs
  schedNum        String?  @unique
  parcelNum       String?
  mapNum          String?

  // Zoning
  zoneId          String?  // e.g. "R-MU-20", "C-MX-5"
  zoneDescription String?  // e.g. "Residential Mixed Use"
  propertyClass   String?  // PROP_CLASS code
  propertyType    String?  // Residential, Commercial, Industrial, Land, Mixed-Use
  propertyDesc    String?  // D_CLASS_CN e.g. "SFR Grade C"

  // Building details
  yearBuilt       Int?
  sqft            Int?     // above-grade area (residential)
  comGrossArea    Int?     // commercial gross area
  comNetArea      Int?     // commercial net area
  comStructType   String?  // commercial structure type
  totalUnits      Int?
  bedrooms        Int?
  bathrooms       Float?
  stories         Int?
  lotSize         Float?   // LAND_AREA in sqft

  // Valuation
  appraisedLand   Float?
  appraisedImprove Float?
  appraisedTotal  Float?
  assessedLand    Float?
  assessedBldg    Float?
  assessedTotal   Float?
  exemptAmt       Float?
  taxableAmt      Float?
  assessedValue   Float?   // alias for assessedTotal
  marketValue     Float?   // alias for appraisedTotal

  // Sales history (most recent)
  lastSalePrice   Float?
  lastSaleDate    DateTime?
  lastSaleYear    Int?
  saleInstrument  String?  // deed type

  // Owner
  ownerName       String?
  ownerAddress    String?
  ownerCity       String?
  ownerState      String?
  ownerZip        String?

  // Listing info (from external sources)
  listingStatus   String?
  listPrice       Float?
  listDate        DateTime?
  listingUrl      String?
  listingSource   String?
  daysOnMarket    Int?
  taxAmount       Float?

  // Metadata
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  dataSource      String?

  searches        SearchResult[]
  savedBy         SavedProperty[]
  salesHistory    SaleRecord[]

  @@index([latitude, longitude])
  @@index([inOpportunityZone])
  @@index([censusTract])
  @@index([listingStatus])
  @@index([zipCode])
  @@index([zoneId])
  @@index([propertyType])
  @@index([address])
}

// Individual sale records for full history
model SaleRecord {
  id            String   @id @default(cuid())
  propertyId    String
  property      Property @relation(fields: [propertyId], references: [id])
  saleDate      DateTime?
  saleYear      Int?
  salePrice     Float?
  instrument    String?
  receptionNum  String?
  createdAt     DateTime @default(now())

  @@index([propertyId])
  @@index([saleYear])
}

model SearchResult {
  id            String   @id @default(cuid())
  searchQuery   String
  latitude      Float
  longitude     Float
  inOZ          Boolean
  censusTract   String?
  ozName        String?
  propertyId    String?
  property      Property? @relation(fields: [propertyId], references: [id])
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

model SavedProperty {
  id              String   @id @default(cuid())
  propertyId      String
  property        Property @relation(fields: [propertyId], references: [id])
  notes           String?
  investmentAmount Float?
  capitalGain     Float?
  holdingPeriod   Int?
  projectedReturn Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([propertyId])
}

model ListingSync {
  id            String   @id @default(cuid())
  source        String
  zipCode       String?
  censusTract   String?
  totalFound    Int      @default(0)
  totalImported Int      @default(0)
  status        String   @default("pending")
  errorMessage  String?
  startedAt     DateTime @default(now())
  completedAt   DateTime?

  @@index([status])
  @@index([startedAt])
}

model OpportunityZone {
  id              String  @id @default(cuid())
  tractId         String  @unique
  name            String
  county          String
  state           String  @default("CO")
  designation     String
  medianIncome    Float?
  povertyRate     Float?
  population      Int?
  boundaryGeoJson String?

  @@index([county])
}
